#!/bin/sh
# PATH shim: intercepts `npx` and redirects to `pnpm exec`
#
# This file is injected ahead of the real `npx` binary via [env] _.path in mise.toml.
# It activates for all sessions (agent and developer) within the project directory.
#
# This project uses pnpm exclusively. npx is not needed — pnpm exec provides
# the same functionality without polluting the global cache.
#
# To bypass this shim in an emergency: use the full path to npx, e.g.
#   $(mise where node)/bin/npx ...

ORIG_ARGS="$*"

RED="\033[31m"
YELLOW="\033[33m"
BOLD="\033[1m"
RESET="\033[0m"

echo "" >&2
echo "${RED}${BOLD}✗ npx is not allowed in this project.${RESET}" >&2
echo "" >&2
echo "  Use ${BOLD}pnpm exec${RESET} instead." >&2
echo "" >&2
echo "  You ran:    npx $ORIG_ARGS" >&2
echo "  Use this:   ${YELLOW}${BOLD}pnpm exec ${ORIG_ARGS}${RESET}" >&2
echo "" >&2
echo "  See AGENTS.md for pnpm conventions." >&2
echo "" >&2
exit 1
